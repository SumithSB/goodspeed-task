# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Optional — Postgres URI for `pnpm db:migrate` (Dashboard → Database → Connection string)
DATABASE_URL=
# Or set only the database password; script builds the pooler URI from NEXT_PUBLIC_SUPABASE_URL
SUPABASE_DB_PASSWORD=

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# AI Provider (OpenAI-compatible)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
# Embeddings — optional overrides (defaults to chat provider above)
AI_EMBEDDING_BASE_URL=
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-3-small
# Must match pgvector column in supabase/migrations (default 1536)
EMBEDDING_DIMENSION=1536

# RAG tuning
RAG_CHUNK_SIZE=2000
RAG_CHUNK_OVERLAP=250
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
# App-layer relevance gate — chunks below this are not passed to the chat LLM
RAG_RELEVANCE_THRESHOLD=0.35

# Chat context window — recent turns kept verbatim; older turns folded into a
# rolling per-conversation summary once they exceed the token budget.
CHAT_RECENT_TURNS=6
CHAT_HISTORY_TOKEN_BUDGET=1500
